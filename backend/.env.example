# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aether_sentinel
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aether_sentinel
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Blockchain Configuration
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
PRIVATE_KEY=your_private_key_here
TOKENIZED_VAULT_ADDRESS=0x...
RISK_GUARDIAN_ADDRESS=0x...
PREDICTION_MARKET_ADDRESS=0x...
GOVERNANCE_MODULE_ADDRESS=0x...

# AI Risk Engine Configuration
AI_RISK_ENGINE_URL=http://localhost:8000
AI_RISK_ENGINE_API_KEY=your_api_key_here

# World ID Configuration
WORLD_ID_APP_ID=your_app_id
WORLD_ID_ACTION_ID=your_action_id
WORLD_ID_API_URL=https://developer.worldcoin.org/api/v1

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3001

# Cache TTL (seconds)
RISK_ASSESSMENT_CACHE_TTL=60
WORLD_ID_CACHE_TTL=300
