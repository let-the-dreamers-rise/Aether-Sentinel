# Chainlink CRE Environment Variables
# Copy this file to .env and fill in your values

# Private key for Sepolia transactions (funded with Sepolia ETH)
CRE_ETH_PRIVATE_KEY=YOUR_64_CHARACTER_PRIVATE_KEY_HERE

# Sepolia RPC URL (e.g. from Alchemy or Infura)
CRE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# AI Risk Engine URL (your deployed FastAPI instance)
AI_RISK_ENGINE_URL=http://localhost:8000
AI_RISK_ENGINE_API_KEY=your_api_key_here

# Deployed contract addresses on Sepolia
TOKENIZED_VAULT_ADDRESS=0xYOUR_VAULT_ADDRESS
RISK_GUARDIAN_ADDRESS=0xYOUR_RISK_GUARDIAN_ADDRESS
PREDICTION_MARKET_ADDRESS=0xYOUR_PREDICTION_MARKET_ADDRESS
